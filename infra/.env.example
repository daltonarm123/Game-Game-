# Core
NODE_ENV=development

# Shared infra
DATABASE_URL=postgresql://gamegame:gamegame@localhost:5432/gamegame
REDIS_URL=redis://localhost:6379

# API
API_PORT=8080
LOCAL_DEMO_FAST=0
FAST_BUILD_SECONDS=5
FAST_TRAIN_SECONDS=5
ATTACK_RETURN_SECONDS=20
EXPLORE_MIN_EFFECTIVE_POWER=25
EXPLORE_POWER_TO_LAND=0.08

# Game server worker
# 300s => exactly :00/:05/:10 ticks
TICK_INTERVAL_SECONDS=300
TICK_ALIGN_SECONDS=300
